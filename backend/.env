# Database (SQLite for testing)
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="miiracer-super-secret-jwt-key-2024-badminton-tournament-management"
JWT_EXPIRES_IN="24h"

# Server
PORT=5000
NODE_ENV="development"

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH="./uploads"

# Google Maps API (베트남용)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"

# Admin Default Account
ADMIN_EMAIL="admin@miiracer.com"
ADMIN_PASSWORD="admin123!"

# Timezone (Vietnam)
TZ="Asia/Ho_Chi_Minh"